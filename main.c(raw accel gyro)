uint8_t icm_id;
int16_t accel_x;
#define CS_PORT GPIOB
#define CS_PIN  GPIO_PIN_6

// Register Bank Selection
#define ICM_REG_BANK_SEL  0x7F

// Bank 0 Registers
#define ICM_WHO_AM_I      0x00
#define ICM_USER_CTRL     0x03
#define ICM_PWR_MGMT_1    0x06
#define ICM_ACCEL_XOUT_H  0x2D
#define ICM_GYRO_XOUT_H   0x33

#define ICM_ID            0xEA

#define ACCEL_SENS      16384.0f    /* ±2g   -> LSB/g      */
#define GYRO_SENS       131.0f      /* ±250°/s -> LSB/(°/s) */

int16_t accel_x = 0;
int16_t accel_y = 0;
int16_t accel_z = 0;

// Variabel Gyroscope
int16_t gyro_x = 0;
int16_t gyro_y = 0;
int16_t gyro_z = 0;

