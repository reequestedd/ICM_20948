void ICM_Select(void) {
    HAL_GPIO_WritePin(CS_PORT, CS_PIN, GPIO_PIN_RESET);
    // Beri jeda sepersekian mikrodetik agar sinyal CS stabil di 1.8V
    for(volatile int i=0; i<10; i++);
}
void ICM_Deselect(void) {
    HAL_GPIO_WritePin(CS_PORT, CS_PIN, GPIO_PIN_SET);
}

void ICM_WriteReg(uint8_t reg, uint8_t data) {
    uint8_t txData[2];
    txData[0] = reg & 0x7F;
    txData[1] = data;

    ICM_Select();
    HAL_SPI_Transmit(&hspi1, txData, 2, HAL_MAX_DELAY);
    ICM_Deselect();
}

uint8_t ICM_ReadReg(uint8_t reg) {
    uint8_t txData[2];
    uint8_t rxData[2];

    txData[0] = reg | 0x80; // MSB = 1 untuk Read (Alamat Register)
    txData[1] = 0x00;       // Dummy byte untuk "memancing" clock agar sensor membalas
    __HAL_SPI_CLEAR_OVRFLAG(&hspi1);
    ICM_Select();
    // Mengirim 2 byte sekaligus menerima 2 byte
    HAL_SPI_TransmitReceive(&hspi1, txData, rxData, 2, HAL_MAX_DELAY);
    ICM_Deselect();

    // Jawaban dari sensor selalu berada di byte kedua (rxData[1])
    return rxData[1];
}

void ICM20948_Init(void) {
	HAL_GPIO_WritePin(GPIOE, GPIO_PIN_3, SET);

    ICM_Deselect(); // Pastikan CS High di awal
    HAL_Delay(100);

    // Pilih Bank 0
    ICM_WriteReg(ICM_REG_BANK_SEL, 0x00);

    // Cek ID
    icm_id = ICM_ReadReg(ICM_WHO_AM_I);

    if(icm_id == ICM_ID) {
        // Reset Device (Optional tapi disarankan)
        ICM_WriteReg(ICM_PWR_MGMT_1, 0x80);
        HAL_Delay(10);

        // Wake up & Clock auto select
        ICM_WriteReg(ICM_PWR_MGMT_1, 0x01);

        // Disable I2C Interface (Enable SPI only mode)
        ICM_WriteReg(ICM_USER_CTRL, 0x10);

        // Enable accel & gyro
        ICM_WriteReg(0x07, 0x00);
        HAL_Delay(50);
    }
}

void ICM20948_ReadAccel(void) {
    uint8_t txData[7] = {0}; // 1 byte alamat + 6 byte dummy
    uint8_t rxData[7] = {0};

    // Alamat register X_H dengan bit Read (MSB = 1)
    txData[0] = ICM_ACCEL_XOUT_H | 0x80;

    ICM_Select();
    // Kirim 7 byte, terima 7 byte sekaligus
    HAL_SPI_TransmitReceive(&hspi1, txData, rxData, 7, HAL_MAX_DELAY);
    ICM_Deselect();

    // rxData[0] adalah balasan kosong saat ngirim alamat
    // Data sesungguhnya ada di index 1 sampai 6
    accel_x = (int16_t)((rxData[1] << 8) | rxData[2])/ACCEL_SENS;
    accel_y = (int16_t)((rxData[3] << 8) | rxData[4])/ACCEL_SENS;
    accel_z = (int16_t)((rxData[5] << 8) | rxData[6])/ACCEL_SENS;

//    ax = accel_x;
//    ay = accel_y;
//    az = accel_z;
}

void ICM20948_ReadGyro(void) {
    uint8_t txData[7] = {0};
    uint8_t rxData[7] = {0};

    // Alamat register Gyro X_H dengan bit Read
    txData[0] = ICM_GYRO_XOUT_H | 0x80;

    ICM_Select();
    HAL_SPI_TransmitReceive(&hspi1, txData, rxData, 7, HAL_MAX_DELAY);
    ICM_Deselect();

    gyro_x = (int16_t)((rxData[1] << 8) | rxData[2])/GYRO_SENS;
    gyro_y = (int16_t)((rxData[3] << 8) | rxData[4])/GYRO_SENS;
    gyro_z = (int16_t)((rxData[5] << 8) | rxData[6])/GYRO_SENS;

//    gx = gyro_x;
//    gy = gyro_y;
//    gz = gyro_z;
}
