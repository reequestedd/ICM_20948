void ak09916_init()
{
    // Langkah 1: Enable I2C Master
    uint8_t user_ctrl = read_single_icm20948_reg(ub_0, B0_USER_CTRL);
    user_ctrl |= 0x20;
    write_single_icm20948_reg(ub_0, B0_USER_CTRL, user_ctrl);
    HAL_Delay(100);

    // Clock I2C Master ~345kHz
    write_single_icm20948_reg(ub_3, B3_I2C_MST_CTRL, 0x0D);
    HAL_Delay(100);

    // Langkah 2: Cek ID
    debug_mag_id = read_single_ak09916_reg(MAG_WIA2);

    if(debug_mag_id == 0x09)
    {
        mag_status = true;

        // Langkah 3: Reset mag
        write_single_ak09916_reg(MAG_CNTL3, 0x01);
        HAL_Delay(100);  // <-- Harus 100ms, bukan 50ms

        // Set continuous 100Hz
        write_single_ak09916_reg(MAG_CNTL2, 0x08);;
        HAL_Delay(100);   // <-- Tambah delay biar mode aktif dulu

        // Langkah 4: Setup auto-fetch SLV0
        // Matikan dulu SLV0 sebelum reconfigure
        write_single_icm20948_reg(ub_3, B3_I2C_SLV0_CTRL, 0x00);
        HAL_Delay(100);

        write_single_icm20948_reg(ub_3, B3_I2C_SLV0_ADDR, READ | MAG_SLAVE_ADDR);
        write_single_icm20948_reg(ub_3, B3_I2C_SLV0_REG,  MAG_ST1);
        write_single_icm20948_reg(ub_3, B3_I2C_SLV0_CTRL, 0x80 | 9);

        // Delay I2C Master
        write_single_icm20948_reg(ub_3, 0x02, 0x01);

        // Tunggu sampai buffer terisi data pertama
        HAL_Delay(100);

        uint8_t* verify = read_multiple_icm20948_reg(ub_0, B0_EXT_SLV_SENS_DATA_00, 9);
    }
    else
    {
        mag_status = false;
    }
}

